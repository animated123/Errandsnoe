rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - role: string (required, 'requester', 'runner', or 'admin')
    //   - email: string (required, email format)
    //   - name: string (required)
    //   - phone: string (optional)
    //   - phoneVerified: bool (optional)
    //   - emailVerified: bool (optional)
    //   - theme: string (optional, 'light' or 'dark')
    //
    // Collection: errands
    // Document ID: {errandId}
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - requesterId: string (required)
    //   - requesterName: string (required)
    //   - status: string (required)
    //   - budget: number (required)
    //   - category: string (required)
    //   - pickupLocation: string (required)
    //   - pickupCoordinates: map (required)
    //   - dropoffLocation: string (optional)
    //   - dropoffCoordinates: map (optional)
    //   - shoppingItems: list (optional)
    //   - shoppingList: string (optional)
    //   - houseType: string (optional)
    //   - rentBudgetMin: number (optional)
    //   - rentBudgetMax: number (optional)
    //   - amenities: list (optional)
    //   - targetEstates: list (optional)
    //   - runnerTasks: list (optional)
    //   - createdAt: string (required)
    //   - updatedAt: string (required)
    //
    // Collection: featured_services
    // Document ID: {id}
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - imageUrl: string (required)
    //   - price: number (required)
    //   - category: string (required)
    //
    // Collection: service_listings
    // Document ID: {id}
    // Fields:
    //   - title: string (required)
    //   - price: number (required)
    //   - category: string (required)
    //   - description: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "ngugimaina4@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'email', 'role']) &&
             data.role in ['requester', 'runner', 'admin'];
    }

    function isValidErrand(data) {
      return data.keys().hasAll(['title', 'requesterId', 'requesterName', 'status', 'budget', 'category', 'pickupLocation', 'pickupCoordinates']) &&
             data.requesterId == request.auth.uid;
    }

    function isValidFeaturedService(data) {
      return data.keys().hasAll(['title', 'description', 'imageUrl', 'price', 'category']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() < 500 &&
             data.imageUrl is string && isValidUrl(data.imageUrl) &&
             data.price is number && data.price >= 0 &&
             data.category is string;
    }

    function isValidServiceListing(data) {
      return data.keys().hasAll(['title', 'price', 'category', 'description']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.description is string && data.description.size() < 500;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // GLOBAL RESTRICTION: Only admins can read or write any data by default.
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // USER PROFILES: Allow users to manage their own profiles.
    match /users/{userId} {
      // Allow a user to read their own document.
      allow get: if isOwner(userId);
      
      // Allow registration.
      allow create: if isOwner(userId) && 
        isValidUser(request.resource.data) && 
        !('isAdmin' in request.resource.data);
      
      // Allow users to update their own settings, but NOT their role, admin status, or ratings.
      // Allow other authenticated users to update ONLY rating and ratingCount.
      allow update: if (isOwner(userId) && 
        (isAdmin() || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isAdmin', 'rating', 'ratingCount']))) ||
        (!isOwner(userId) && isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'ratingCount']));
    }

    // ERRANDS: Requesters can create, everyone can read (for runners to see).
    match /errands/{errandId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidErrand(request.resource.data);
      allow update: if isAuthenticated() && (
        // Requester can update their own errand (e.g. cancel, accept bid)
        (resource.data.requesterId == request.auth.uid) ||
        // Runner can update if they are assigned or bidding
        (request.auth.uid == request.resource.data.runnerId) ||
        (request.resource.data.bids != null) ||
        isAdmin()
      );
    }

    // FEATURED SERVICES: Authenticated users can read, only admins can write.
    match /featured_services/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidFeaturedService(request.resource.data);
    }

    // SERVICE LISTINGS: Authenticated users can read, only admins can write.
    match /service_listings/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidServiceListing(request.resource.data);
    }

    // NOTIFICATIONS: Only the user can read their own notifications.
    match /notifications/{id} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }

    // RUNNER APPLICATIONS: Users can create, admins can read/write.
    match /runner_applications/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, write: if isAdmin();
    }

    // SUPPORT CHATS: Users can read/write their own chat.
    match /support_chats/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /messages/{messageId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // SETTINGS: Allow all users to read global settings for UI rendering 
    // and connection testing.
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
