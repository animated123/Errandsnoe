rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - role: string (required, 'USER' or 'ADMIN')
    //   - email: string (required, email format)
    //   - name: string (required)
    //   - phone: string (optional)
    //   - phoneVerified: bool (optional)
    //   - emailVerified: bool (optional)
    //   - theme: string (optional, 'light' or 'dark')
    //
    // Collection: verification_codes
    // Document ID: {phone}
    // Fields:
    //   - otp: string (required, 6 digits)
    //   - expiresAt: number (required, timestamp in ms)
    //   - createdAt: timestamp (required)
    //
    // Collection: settings
    // Document ID: global
    // Fields:
    //   - primaryColor: string (optional)
    //   - appName: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN') ||
          (request.auth.token.email == "ngugimaina4@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // GLOBAL RESTRICTION: Only admins can read or write any data by default.
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // USER PROFILES: Allow users to manage their own profiles.
    match /users/{userId} {
      // Allow a user to read their own document.
      allow get: if isOwner(userId);
      
      // Allow registration.
      allow create: if isOwner(userId) && 
        request.resource.data.role == 'USER' && 
        !('isAdmin' in request.resource.data);
      
      // Allow users to update their own settings, but NOT their role or admin status.
      allow update: if isOwner(userId) && 
        (isAdmin() || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isAdmin']));
    }

    // VERIFICATION CODES: Managed by server via Admin SDK.
    // No client access needed.
    match /verification_codes/{phone} {
      allow read, write: if false;
    }

    // SETTINGS: Allow all users to read global settings for UI rendering 
    // and connection testing.
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
