rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: global
    // Fields:
    //   - appName: string
    //   - primaryColor: string
    //   - logoUrl: string
    //   - iconUrl: string
    //   - platformFee: number
    //   - minErrandPrice: number
    //   - maintenanceMode: bool
    //
    // Collection: featured_services
    // Document ID: auto-generated
    // Fields:
    //   - id: string
    //   - title: string
    //   - description: string
    //   - imageUrl: string
    //   - price: number
    //   - category: string
    //
    // Collection: service_listings
    // Document ID: auto-generated
    // Fields:
    //   - id: string
    //   - title: string
    //   - price: number
    //   - category: string
    //   - description: string
    //
    // Collection: errands
    // Document ID: auto-generated
    // Fields:
    //   - id: string
    //   - title: string
    //   - description: string
    //   - requesterId: string
    //   - requesterName: string
    //   - runnerId: string
    //   - runnerName: string
    //   - status: string
    //   - price: number
    //   - acceptedPrice: number
    //   - category: string
    //   - location: map
    //   - createdAt: string
    //   - updatedAt: string
    //
    // Collection: notifications
    // Document ID: auto-generated
    // Fields:
    //   - id: string
    //   - userId: string
    //   - title: string
    //   - message: string
    //   - type: string
    //   - read: bool
    //   - createdAt: string
    //
    // Collection: runner_applications
    // Document ID: auto-generated
    // Fields:
    //   - id: string
    //   - userId: string
    //   - fullName: string
    //   - nationalId: string
    //   - phone: string
    //   - categoryApplied: string
    //   - idFrontUrl: string
    //   - idBackUrl: string
    //   - status: string
    //   - createdAt: string
    //
    // Collection: support_chats
    // Document ID: userId
    // Fields:
    //   - id: string
    //   - userId: string
    //   - userName: string
    //   - lastMessage: string
    //   - lastMessageAt: number
    //   - unreadByAdmin: bool
    //   - unreadByUser: bool
    //
    // Collection: support_chats/{userId}/messages
    // Document ID: auto-generated
    // Fields:
    //   - id: string
    //   - senderId: string
    //   - senderName: string
    //   - text: string
    //   - createdAt: number
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "ngugimaina4@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "Errands@codexict.co.ke" && request.auth.token.email_verified == true)
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /featured_services/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /service_listings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /errands/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /notifications/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /runner_applications/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /support_chats/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);
      
      match /messages/{messageId} {
        allow read: if isAdmin() || isOwner(userId);
        allow write: if isAdmin() || isOwner(userId);
      }
    }
  }
}
