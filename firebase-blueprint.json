{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "runner", "admin"] },
        "points": { "type": "number" },
        "isRunner": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Errand": {
      "title": "Errand",
      "description": "An errand task posted by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "clientId": { "type": "string" },
        "runnerId": { "type": "string" },
        "budget": { "type": "number" },
        "acceptedPrice": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "clientId", "status"]
    },
    "Application": {
      "title": "Application",
      "description": "Runner application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["id", "userId", "fullName", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/errands/{errandId}": {
      "schema": "Errand",
      "description": "Errand task documents"
    },
    "/applications/{appId}": {
      "schema": "Application",
      "description": "Runner applications"
    }
  }
}
